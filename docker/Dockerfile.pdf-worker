# DORINC Suite — pdf-worker polls pdf_render_jobs and calls laravel-pdf (DomPDF).
FROM node:24-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --ignore-scripts
COPY server/workers ./server/workers
COPY server/lib ./server/lib
COPY server/db/migrations ./server/db/migrations
ENV NODE_ENV=production
CMD ["node", "server/workers/pdf-worker.mjs"]
