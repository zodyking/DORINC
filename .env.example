# DORINC Suite — zero required environment variables
#
# Deploy the container, open /setup, and configure everything in the UI.
#
# Stored automatically by the setup wizard:
#   .data/runtime.json     — PostgreSQL connection
#   app_settings (DB)     — SMTP, encryption keys, app URL (encrypted)
#
# Optional overrides for CI/tests or advanced operators only:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# APP_URL=https://invoices.example.com
# SESSION_SECRET=
# ENCRYPTION_MASTER_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
#
# Docker: persistent volume at /app/.data (see docker-compose.yml dorinc-runtime)
