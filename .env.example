# ============================================================
# DORINC Suite — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Database (REQUIRED) ---
# PostgreSQL is EXTERNAL to the compose stack (SPEC §2).
#
# Development on this machine uses the local PostgreSQL 18 service:
#   DATABASE_URL=postgresql://postgres:<password>@localhost:5432/dorinc
# Production (Dockploy): point at your managed/external PostgreSQL host.
DATABASE_URL=postgresql://postgres:password@localhost:5432/dorinc

# --- App (REQUIRED) ---
APP_URL=http://localhost:3000
# 32+ random bytes, e.g. `openssl rand -hex 32`
SESSION_SECRET=change-me-64-hex-chars
# 32-byte hex key for AES-256-GCM encryption of stored secrets (OpenRouter, Google tokens)
ENCRYPTION_MASTER_KEY=change-me-64-hex-chars

# --- SMTP (REQUIRED for email verification / credential sends) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=change-me
SMTP_FROM="DORINC Suite <mailer@example.com>"

# --- Bootstrap (REQUIRED) ---
# Email allowed to complete first-run Super Admin setup
ADMIN_BOOTSTRAP_EMAIL=owner@example.com

# --- Uploads (REQUIRED) ---
MAX_UPLOAD_MB=25

# --- Optional ---
# REDIS_URL=redis://redis:6379
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BACKUP_SCHEDULE=0 3 * * *
# OCR_ENABLED=false
# NODE_ENV=production
# LOG_LEVEL=info
