# ============================================================
# DORINC Suite — environment variables (production reference)
# Copy to .env and fill in real values. NEVER commit .env.
# Spec: Agent-Files/SPEC.md §20
# ============================================================

# ------------------------------------------------------------
# REQUIRED — all deployments (nuxt-app + workers)
# ------------------------------------------------------------

# PostgreSQL connection string. Database is EXTERNAL to Docker Compose
# (managed Postgres, Dockploy external DB, or dedicated host). Never run
# Postgres inside the compose stack.
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Dev (local):  postgresql://postgres:<password>@localhost:5432/dorinc
# Prod:         postgresql://dorinc_app:<password>@db.example.com:5432/dorinc
DATABASE_URL=postgresql://postgres:password@localhost:5432/dorinc

# Public base URL of the app (no trailing slash). Used for:
# - session cookie secure context
# - customer credential / invoice / estimate email links
# - OpenRouter HTTP-Referer header
# - Google Drive OAuth redirect base
APP_URL=http://localhost:3000

# Session signing secret (32+ random bytes). Used for:
# - HTTP-only session cookies (staff + portal)
# - Google Drive OAuth state signing
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-64-hex-chars

# AES-256-GCM master key for encrypting stored secrets (32-byte hex). Used for:
# - OpenRouter API key (ai_provider_settings)
# - Google Drive OAuth refresh tokens (backup_integrations)
# - Encrypted backup artifacts
# Generate: openssl rand -hex 32
# WARNING: changing this invalidates all encrypted secrets and backups.
ENCRYPTION_MASTER_KEY=change-me-64-hex-chars

# SMTP — required for email verification, credential sends, invoice/estimate
# delivery, backup notifications, and portal request status emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=change-me
SMTP_FROM="DORINC Suite <mailer@example.com>"

# Email allowed to complete first-run Super Admin setup wizard.
# After bootstrap, this is informational only.
ADMIN_BOOTSTRAP_EMAIL=owner@example.com

# Maximum upload size in megabytes (service log photos, file attachments).
# Enforced server-side on POST /api/files.
MAX_UPLOAD_MB=25

# ------------------------------------------------------------
# OPTIONAL — features and tuning
# ------------------------------------------------------------

# Node environment. Set to production in Dockploy / compose services.
# Affects: secure session cookies, SMTP error handling, mail worker behavior.
NODE_ENV=production

# Redis URL for optional distributed queue (profile: redis).
# Default job queues use PostgreSQL worker_jobs / pdf_render_jobs tables.
# REDIS_URL=redis://redis:6379

# Google Drive backup integration (Super Admin → Control Panel).
# Create OAuth 2.0 credentials with redirect:
#   {APP_URL}/api/admin/backups/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cron expression for nightly encrypted backup enqueue (worker scheduler).
# Default: 0 2 * * * (02:00 UTC daily). Override in Control Panel settings too.
# BACKUP_SCHEDULE=0 2 * * *

# Worker job poll interval in milliseconds.
# general worker default: 5000 | pdf-worker default: 3000
# WORKER_POLL_MS=5000

# Future OCR pipeline toggle (not wired in MVP; reserved per SPEC §20).
# OCR_ENABLED=false

# Application log verbosity (reserved; defaults to info when unset).
# LOG_LEVEL=info

# ------------------------------------------------------------
# DOCKER COMPOSE / DOCKPLOY — set in compose or Dockploy UI
# ------------------------------------------------------------
# These are set automatically by docker-compose.yml; override only if needed.
#
# NITRO_HOST=0.0.0.0          # nuxt-app listen address
# NITRO_PORT=3000             # nuxt-app listen port
# WORKER_KIND=general         # worker service: general | pdf (set per container)

# ------------------------------------------------------------
# SERVICE MATRIX — which vars each container needs
# ------------------------------------------------------------
#
# nuxt-app (default profile):
#   DATABASE_URL, APP_URL, SESSION_SECRET, ENCRYPTION_MASTER_KEY,
#   SMTP_*, ADMIN_BOOTSTRAP_EMAIL, MAX_UPLOAD_MB, NODE_ENV
#   Optional: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#
# worker (profile: workers):
#   DATABASE_URL, ENCRYPTION_MASTER_KEY, SESSION_SECRET,
#   SMTP_*, APP_URL, ADMIN_BOOTSTRAP_EMAIL, NODE_ENV
#   Optional: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, BACKUP_SCHEDULE,
#             WORKER_POLL_MS, REDIS_URL
#
# pdf-worker (profile: workers):
#   DATABASE_URL, NODE_ENV
#   Optional: WORKER_POLL_MS
#
# migrate (profile: migrate, one-shot):
#   DATABASE_URL only
#
# redis (profile: redis):
#   No DORINC-specific vars; expose REDIS_URL to workers if used.

# ------------------------------------------------------------
# DEPLOYMENT CHECKLIST (Dockploy + external PostgreSQL)
# ------------------------------------------------------------
# 1. Provision external PostgreSQL 16+ and create database + role.
# 2. Copy this file to .env on the host; fill all REQUIRED values.
# 3. Run migrations: docker compose run --rm migrate
# 4. Start app: docker compose up -d
# 5. Start workers: docker compose --profile workers up -d
# 6. Complete first-run setup at {APP_URL}/setup (Super Admin bootstrap).
# 7. Configure SMTP test + AI settings in Super Admin Control Panel.
# 8. Verify health: GET {APP_URL}/api/health → 200

# ------------------------------------------------------------
# SECURITY NOTES
# ------------------------------------------------------------
# - Never commit .env or paste secrets into compose files.
# - Rotate SESSION_SECRET and ENCRYPTION_MASTER_KEY only with a migration plan.
# - Use TLS SMTP (port 587 STARTTLS or 465 SSL) in production.
# - APP_URL must match the public HTTPS origin for secure cookies.
# - GOOGLE_CLIENT_SECRET and SMTP_PASS are server-only; never exposed to browser.
